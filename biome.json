{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "off",
        "noDuplicateClasses": "off",
        "useSortedKeys": "off",
        "useSortedProperties": "off",
        "useSortedAttributes": "off",
        "useSortedInterfaceMembers": "off"
      }
    }
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120,
    "lineEnding": "lf"
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "arrowParentheses": "always",
      "attributePosition": "multiline",
      "lineWidth": 120
    }
  },
  "linter": {
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noDuplicateFontNames": "off"
      },
      "style": {
        "noUselessElse": "off",
        "noDescendingSpecificity": "off",
        "useSelfClosingElements": "off"
      },
      "complexity": {
        "noUselessSwitchCase": "off"
      },
      "a11y": {
        "useKeyWithClickEvents": "off",
        "noLabelWithoutControl": "off"
      },
      "correctness": {
        "noUnusedFunctionParameters": "off"
      }
    }
  },
  "files": {
    "includes": [
      "./src/**",
      "./biome.json",
      "./package.json",
      "./postcss.config.mjs",
      "./rsbuild.config.ts",
      "./tsconfig.json"
    ],
    "ignoreUnknown": true
  }
}
